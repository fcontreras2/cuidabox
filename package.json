{
  "name": "cuidabox",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:website": "npm run dev --workspace=apps/website",
    "dev:app": "npm run dev --workspace=apps/app",
    "dev:doc": "npm run dev --workspace=apps/doc",
    "build": "npm run build --workspaces --if-present",
    "build:website": "npm run build --workspace=apps/website",
    "build:app": "npm run build --workspace=apps/app",
    "build:doc": "npm run build --workspace=apps/doc",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
